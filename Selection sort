 void selectionSort(int arr[], int n)
    {
        int mini = 0;
        int m = 0;
        for (int i=0; i<n; i++){
           mini = i;
           for(int j=i; j<n; j++){
               if(arr[j]< arr[mini]){
                   mini = j;
               }
           }
           int temp = arr[mini];
           arr[mini] = arr[i];
           arr[i] = temp;
       }
    }

Time Complexity: O(n^2)
Space complexity: O(1)
